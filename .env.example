# Firebase web config (public client identifiers — safe to expose; access is
# enforced by Firestore security rules). Copy these into .env.local and fill in
# the values from Firebase console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Anthropic API key for byte's live task loop (Phase 3). SERVER-SIDE ONLY —
# do not prefix with NEXT_PUBLIC. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Firebase Admin (server-side). The /api/run-task route verifies the caller's
# Firebase ID token. Verification works with just the project id above — these
# are OPTIONAL, only needed for privileged Admin ops (custom tokens, checkRevoked).
# From Firebase console → Project settings → Service accounts → Generate new key.
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Sentry error tracking (Phase 4). Optional — the app no-ops without it. The DSN
# is safe to expose (NEXT_PUBLIC). Create a project at https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=
