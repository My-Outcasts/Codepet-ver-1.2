{
  "name": "codepet-v1-2",
  "version": "1.2.0",
  "private": true,
  "description": "Codepet — your AI building companion. Run your whole company with AI, department by department.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore --project demo-codepet-rules \"vitest run --config vitest.rules.config.ts\"",
    "test:installer": "node --test lib/installer/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@sentry/nextjs": "^10.62.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^14.1.0",
    "jose": "^6.2.3",
    "next": "^16.2.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-force-graph-3d": "^1.29.1",
    "server-only": "^0.0.1",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.12.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@types/three": "^0.185.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^15.22.4",
    "prettier": "^3.9.4",
    "typescript": "5.7.2",
    "vitest": "^3.2.6"
  }
}
