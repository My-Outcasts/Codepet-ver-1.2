rules_version = '2';

// Codepet Firestore security rules — SHARED project devpet-8f4b1 (iOS app + web app).
// This file MERGES the existing iOS-app rules (users + feedback) with the new web-app
// rules (companies). Firestore is deny-by-default, so anything not matched here is
// blocked for client access — collections used only by Cloud Functions / the Admin SDK
// (dictionary_cache, narratives_cache, usage) don't need rules and are intentionally
// omitted, exactly as before.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ---- Existing (iOS app) ----

    // A user owns their profile doc AND anything nested under it
    // (e.g. users/{uid}/extensions/cursor). The web app also writes users/{uid}.
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // App feedback — anyone using the app can submit a valid payload; clients can't
    // read or edit. Restored verbatim from the previous ruleset.
    match /feedback/{docId} {
      allow create: if request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.feature is string;
      allow read, update, delete: if false;
    }

    // ---- New (Codepet web — companies) ----
    // Model: a user owns exactly one company whose id equals their uid (v1). Rules are
    // written for membership so teams work later without a rewrite, but ownership has a
    // get()-free fast path. That fast path is also what lets the sign-up *batch* seed a
    // company + its subcollections in one commit — inside a batch, get() can't see the
    // company doc being created alongside the subdocs.

    // v1 convention: your company id is your uid. No get(), so it holds even during
    // the seeding batch before the company doc is committed.
    function ownsByConvention(companyId) {
      return signedIn() && request.auth.uid == companyId;
    }

    // Team-member check for the future multi-member case (safe outside batched seeds).
    function isMember(companyId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/companies/$(companyId)).data.memberIds;
    }

    // Ownership must never change on an update — no escalating yourself to owner.
    function ownershipUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    match /companies/{companyId} {
      // Creator must own the company by convention and list themselves as a member.
      // ownerId/memberIds are pinned to the caller, so a company can only ever be
      // created for the account that owns it.
      allow create: if signedIn()
        && companyId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds;

      allow read: if ownsByConvention(companyId) || isMember(companyId);

      // Owner (by convention) may edit company data and manage the member list, but
      // can never reassign ownership. A non-owner member may edit data only — not
      // ownerId and not the member list (no privilege escalation).
      allow update: if (ownsByConvention(companyId) && ownershipUnchanged())
        || (isMember(companyId)
            && ownershipUnchanged()
            && request.resource.data.memberIds == resource.data.memberIds);

      // Only the owner can delete the whole company.
      allow delete: if ownsByConvention(companyId);

      // Departments, library, chat, and any future per-company subcollection — scoped
      // to the company's owner/members. Deny-by-default keeps every other account out.
      // The leading {sub} segment is load-bearing: a v2 recursive wildcard matches ZERO
      // or more segments, so a bare `match /{document=**}` here would also match the
      // company doc itself and blanket-grant write on it — bypassing the strict
      // create/update/delete rules above (e.g. letting a plain member escalate to owner
      // or delete the company). Requiring {sub} keeps this strictly below the doc.
      match /{sub}/{document=**} {
        allow read, write: if ownsByConvention(companyId) || isMember(companyId);
      }
    }
  }
}
